# =====================================================================
# LSTracker — variables d'environnement PRODUCTION
# Copier ce fichier en .env.prod (ne JAMAIS commit).
# Lance : docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# =====================================================================

# ---- Image Docker à pull depuis ghcr.io (sortie de GitHub Actions) ----
# Format : ghcr.io/<org>/labsampletracker:<tag>
# Exemples :
#   :latest                                 (toujours la dernière, danger)
#   :2.2.0                                  (tag versionné, recommandé)
#   :sha-abc1234                            (commit précis)
APP_IMAGE=ghcr.io/itech-ci/labsampletracker:2.2.0

# ---- Port public ----
PROD_PORT=9200

# ---- Base de données ----
# POSTGRES_USER : identique entre envs (appuser).
#   - Les containers sont isolés (networks Docker distincts), pas de risque.
#   - Bénéfice : dumps pg_dump portables entre envs sans manipulation.
# POSTGRES_DB et POSTGRES_PASSWORD restent évidemment différents de la demo.
POSTGRES_DB=sample_tracker_prod
POSTGRES_USER=appuser
# Générer : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# ---- JWT signing secret ----
# Format obligatoire : base64 (JwtService.decode utilise Decoders.BASE64).
# Générer : openssl rand -base64 64 | tr -d '\n'
# = 64 bytes encodés en base64 (~88 chars, ≈ 512 bits effectifs).
# DOIT être différent de la demo.
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_base64_64

JWT_EXPIRATION_MINUTES=43200
JWT_REFRESH_TTL_DAYS=60

# ---- Pool DB (production : usage plus intensif) ----
DB_POOL_MAX=50
DB_POOL_MIN=10

# ---- Divers ----
TZ=Africa/Abidjan
