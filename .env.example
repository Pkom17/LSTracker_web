# =====================================================
# LSTracker — environment template
# Copy this file to ".env" and replace every value below.
# Never commit ".env" (it is in .gitignore).
# =====================================================

# ---- Database ----------------------------------------
# Password used both by the postgres container and the
# Spring Boot application.
POSTGRES_DB=sample_tracker
POSTGRES_USER=appuser
# Replace by a strong password (min 20 chars, mixed)
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---- Application -------------------------------------
SERVER_PORT=8050
TZ=Africa/Abidjan

# ---- JWT signing secret ------------------------------
# IMPORTANT: JwtService decodes this value as BASE64, so the secret
# MUST be valid base64 (chars [A-Za-z0-9+/=]).
# Generate with:
#   openssl rand -base64 64 | tr -d '\n'
# 64 random bytes encoded in base64 = ~88 chars (≈ 512 bits), well above
# the 256-bit minimum required by HMAC-SHA256.
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_base64_64

# Token TTLs (minutes / days)
JWT_EXPIRATION_MINUTES=43200
JWT_REFRESH_TTL_DAYS=60

# ---- DB pool tuning (optional) -----------------------
DB_POOL_MAX=30
DB_POOL_MIN=5

# ---- Intégration oedatarepo (OpenELIS consolidé) -----
# Récupération du statut/dates d'analyse par labno. Laisser désactivé en dev
# local sauf si tu testes l'intégration contre un oedatarepo accessible.
OEDATAREPO_ENABLED=false
OEDATAREPO_URL=
OEDATAREPO_USER=
OEDATAREPO_PASSWORD=
# Réglages du job de synchronisation (optionnels, valeurs par défaut ci-dessous)
OEDATAREPO_BATCH_SIZE=200
OEDATAREPO_INTERVAL_MS=1800000
OEDATAREPO_MAX_ATTEMPTS=5
