# =====================================================================
# LSTracker — variables d'environnement DEMO
# Copier ce fichier en .env.demo (ne JAMAIS commit).
# Lance : docker compose --env-file .env.demo -f docker-compose.demo.yml up -d
# =====================================================================

# ---- Image Docker (peut être la même version que prod) ----
APP_IMAGE=ghcr.io/itech-ci/labsampletracker:2.2.0

# ---- Port public ----
DEMO_PORT=9201

# ---- Base de données (différente de la prod) ----
POSTGRES_DB=sample_tracker_demo
POSTGRES_USER=appuser_demo
# Mot de passe différent de la prod (même si environnement de démo).
POSTGRES_PASSWORD=CHANGE_ME_TO_A_DIFFERENT_PASSWORD

# ---- JWT signing secret (DOIT être différent de la prod) ----
# Un token issu de la demo NE DOIT JAMAIS être valide en prod.
JWT_SECRET=CHANGE_ME_DIFFERENT_FROM_PROD

JWT_EXPIRATION_MINUTES=43200
JWT_REFRESH_TTL_DAYS=60

# ---- Pool DB (modeste pour la demo) ----
DB_POOL_MAX=15
DB_POOL_MIN=3

# ---- Divers ----
TZ=Africa/Abidjan
