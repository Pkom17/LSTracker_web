# =====================================================================
# LSTracker — variables d'environnement DEMO
# Copier ce fichier en .env.demo (ne JAMAIS commit).
# Lance : docker compose --env-file .env.demo -f docker-compose.demo.yml up -d
# =====================================================================

# ---- Image Docker (peut être la même version que prod) ----
APP_IMAGE=ghcr.io/itech-ci/labsampletracker:2.2.0

# ---- Port public ----
DEMO_PORT=9201

# ---- Base de données (différente de la prod) ----
# POSTGRES_USER : volontairement IDENTIQUE entre envs (appuser).
#   - Les containers sont isolés (networks Docker distincts), donc pas de
#     risque de cross-access via le user.
#   - Bénéfice : les dumps pg_dump sont portables d'un env à l'autre sans
#     manipulation (GRANT/OWNER référencent le même nom).
POSTGRES_DB=sample_tracker_demo
POSTGRES_USER=appuser
# Mot de passe différent de la prod (même si environnement de démo).
POSTGRES_PASSWORD=CHANGE_ME_TO_A_DIFFERENT_PASSWORD

# ---- JWT signing secret (DOIT être différent de la prod) ----
# Un token issu de la demo NE DOIT JAMAIS être valide en prod.
# Format obligatoire : base64 (JwtService.decode utilise Decoders.BASE64).
# Générer : openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_DIFFERENT_FROM_PROD_BASE64

JWT_EXPIRATION_MINUTES=43200
JWT_REFRESH_TTL_DAYS=60

# ---- Pool DB (modeste pour la demo) ----
DB_POOL_MAX=15
DB_POOL_MIN=3

# ---- Intégration oedatarepo (OpenELIS consolidé) ----
# Pointer vers l'instance oedatarepo correspondant à la DEMO.
OEDATAREPO_ENABLED=false
OEDATAREPO_URL=https://oedatarepo-demo.itech-civ.org
OEDATAREPO_USER=CHANGE_ME_compte_technique_lstracker
OEDATAREPO_PASSWORD=CHANGE_ME
# Réglages du job de synchronisation (optionnels)
OEDATAREPO_BATCH_SIZE=200
OEDATAREPO_INTERVAL_MS=1800000
OEDATAREPO_MAX_ATTEMPTS=5

# ---- Divers ----
TZ=Africa/Abidjan
